{
  "manifest_version": 3,
  "name": "Calipers",
  "version": "0.1.0",
  "description": "Select a measurement, right-click: the context menu itself shows the conversions — every unit, plus circle geometry. Click a value to copy it.",
  "author": "Maxamilian X J Kidd-May",
  "homepage_url": "https://github.com/kiddersmxj/calipers",
  "browser_specific_settings": {
    "gecko": {
      "id": "calipers@kiddersmxj.github.io",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["menus", "scripting", "activeTab", "clipboardWrite"]
}
